            }
            mapTarget {
                String deviceRegistryUrl;
                String deviceIdentifier;
                String deviceLookupUrl;
            }
            set (variable) deviceLookupUrl = "%deviceRegistryUrl%%deviceIdentifier%";
        };
        INVOKE pub.client:http {
            input {
                mapTarget[httpInput] {
                    String url;
                    String method;
                    String loadAs;
                    record data;
                    record auth;
                    record headers;
                    String timeout;
                    String connectTimeout;
                    String maxKeepAliveConnections;
                    String keepAliveTimeout;
