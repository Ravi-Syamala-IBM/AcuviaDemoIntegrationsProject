                }
                mapTarget[jsonStringToDocumentInput] {
                    String jsonString;
                    String jsonDocumentTypeName;
                    String strict;
                    String decodeRealAsDouble;
                    String decodeIntegerAsLong;
                    String decodeRealAsString;
                    String decodeNullRootAsEmpty;
                    String unescapeSpecialChars;
                }
                copy deviceResponseString -> jsonString;
            }
            output {
                mapSource {
                    record document;
                }
                mapTarget {
                    record document;
                    record deviceDetails;
                }
                copy document -> deviceDetails;
            }
        };
        MAP {
            mapSource {
                record deviceDetails {
                    String deviceIdentifier;
