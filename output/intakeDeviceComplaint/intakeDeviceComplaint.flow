            }
            mapTarget {
                String severity;
                Integer complaintCountLast30Days;
                String qualityReviewRequired;
            }
            set qualityReviewRequired = "false";
        };
        IF (%severity% == "high") {
            MAP {
                mapTarget {
                    String qualityReviewRequired;
                }
                set qualityReviewRequired = "true";
            };
        };
        IF (%complaintCountLast30Days% > 1) {
            MAP {
                mapTarget {
                    String qualityReviewRequired;
                }
                set qualityReviewRequired = "true";
            };
        };
        MAP {
            mapSource {
                String qualityReviewRequired;
            }
            mapTarget {
                String qualityReviewRequired;
                String qualityReviewDecision;
            }
            copy qualityReviewRequired -> qualityReviewDecision;
        };
