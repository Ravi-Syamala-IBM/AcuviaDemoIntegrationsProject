                    String keyAlias;
                    String hostNameVerification;
                    String cipherSuites;
                    String checkCRL;
                    String proxyAlias;
                    String followRedirect;
                    String compressionEnabled;
                }
                copy deviceLookupUrl -> url;
                set method = "get";
                set loadAs = "bytes";
                set timeout = "30000";
            }
            output {
                mapSource {
                    String encodedURL;
                    record header;
                    record body {
                        Object bytes;
                        Object stream;
                    };
                }
                mapTarget {
                    String encodedURL;
                    record header;
                    record body;
                    Object deviceResponseBytes;
                }
                copy body/bytes -> deviceResponseBytes;
            }
        };
        INVOKE pub.string:bytesToString {
            input {
                mapSource {
                    Object deviceResponseBytes;
                }
                mapTarget[bytesToStringInput] {
                    Object bytes;
                    String encoding;
                }
                copy deviceResponseBytes -> bytes;
                set encoding = "UTF-8";
            }
            output {
                mapSource {
                    String string;
                }
                mapTarget {
                    String string;
                    String deviceResponseString;
                }
                copy string -> deviceResponseString;
            }
        };
        INVOKE pub.json:jsonStringToDocument {
            input {
                mapSource {
