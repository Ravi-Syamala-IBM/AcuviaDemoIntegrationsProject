service intakeDeviceComplaint (
    input {
        String requestId [required];
        String hospitalId;
        String reportedBy;
        String deviceIdentifier [required];
        String serialNumber [required];
        String lotNumber;
        String severity [required];
        String description;
    }
    output {
        String status;
        String requestId;
        String crmCaseId;
        String qualityReviewDecision;
        String qmsQualityEventId;
        String notificationId;
        String auditId;
        String finalDecision;
        String errorMessage;
    }
) {
    TRY {
        MAP {
            mapSource {
                String requestId;
                String hospitalId;
                String reportedBy;
                String deviceIdentifier;
                String serialNumber;
                String lotNumber;
                String severity;
                String description;
            }
            mapTarget {
                String requestId;
                String hospitalId;
                String reportedBy;
                String deviceIdentifier;
                String serialNumber;
                String lotNumber;
                String severity;
                String description;
                String deviceRegistryUrl;
                String complaintHistoryUrl;
                String crmCaseUrl;
                String qmsQualityEventUrl;
                String notificationUrl;
                String auditEventUrl;
            }
            copy requestId -> requestId;
            copy hospitalId -> hospitalId;
            copy reportedBy -> reportedBy;
            copy deviceIdentifier -> deviceIdentifier;
            copy serialNumber -> serialNumber;
            copy lotNumber -> lotNumber;
            copy severity -> severity;
            copy description -> description;
            set deviceRegistryUrl = "https://acuvia-integration-services.onrender.com/device-registry/udi/";
            set complaintHistoryUrl = "https://acuvia-integration-services.onrender.com/complaints/history";
            set crmCaseUrl = "https://acuvia-integration-services.onrender.com/crm/cases";
            set qmsQualityEventUrl = "https://acuvia-integration-services.onrender.com/qms/quality-events";
            set notificationUrl = "https://acuvia-integration-services.onrender.com/notifications/quality-review";
            set auditEventUrl = "https://acuvia-integration-services.onrender.com/audit/events";
        };
        MAP {
            mapSource {
