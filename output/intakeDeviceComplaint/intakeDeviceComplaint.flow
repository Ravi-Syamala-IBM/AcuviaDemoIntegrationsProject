                    set method = "post";
                    set loadAs = "bytes";
                    set timeout = "30000";
                    set headers/Content-Type = "application/json";
                    copy qmsPayload -> data;
                }
                output {
                    mapSource {
                        String encodedURL;
                        record header;
                        record body {
                            Object bytes;
                            Object stream;
                        };
                    }
                    mapTarget {
                        String encodedURL;
                        record header;
                        record body;
                        Object qmsResponseBytes;
                    }
                    copy body/bytes -> qmsResponseBytes;
                }
