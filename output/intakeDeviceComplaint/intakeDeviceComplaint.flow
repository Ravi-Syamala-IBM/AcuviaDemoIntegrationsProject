                        String jsonDocumentTypeName;
                        String strict;
                        String decodeRealAsDouble;
                        String decodeIntegerAsLong;
                        String decodeRealAsString;
                        String decodeNullRootAsEmpty;
                        String unescapeSpecialChars;
                    }
                    copy qmsResponseString -> jsonString;
                }
                output {
